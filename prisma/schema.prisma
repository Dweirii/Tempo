// Brandex/Tempo Studio Planner — shared Postgres (Neon) schema.
// Multi-tenant: every row is scoped by `orgId` (the active Clerk organization,
// or "default" when Clerk is disabled). Primary key is the composite
// (orgId, id) so the engine's deterministic ids (e.g. "week-1-1") stay unique
// across organizations. Domain types stay orgId-free — orgId is added/stripped
// at the actions boundary.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Category {
  orgId         String
  id            String
  name          String
  slug          String
  order         Int
  productCount  Int
  color         String
  subcategories Subcategory[]
  weeks         Week[]

  @@id([orgId, id])
  @@unique([orgId, slug])
}

model Subcategory {
  orgId        String
  id           String
  categoryId   String
  category     Category @relation(fields: [orgId, categoryId], references: [orgId, id], onDelete: Cascade)
  name         String
  used         Boolean  @default(false)
  usedInWeekId String?
  order        Int

  @@id([orgId, id])
  @@index([orgId, categoryId])
}

model Week {
  orgId         String
  id            String
  weekNumber    Int
  blockNumber   Int
  categoryId    String
  category      Category      @relation(fields: [orgId, categoryId], references: [orgId, id], onDelete: Cascade)
  subcategoryId String
  theme         String
  startDate     String
  storyRotation Json
  contentItems  ContentItem[]

  @@id([orgId, id])
  @@index([orgId, categoryId])
}

model ContentItem {
  orgId         String
  id            String
  weekId        String
  week          Week    @relation(fields: [orgId, weekId], references: [orgId, id], onDelete: Cascade)
  date          String
  dayOfWeek     Int
  slot          String
  format        String
  concept       String
  caption       String
  hashtags      String
  assetUrl      String
  trendingAudio String
  productSku    String
  owner         String
  assignee      String
  status        String
  assets        Asset[]

  @@id([orgId, id])
  @@index([orgId, weekId])
  @@index([orgId, date])
}

model Asset {
  orgId         String
  id            String
  contentItemId String
  contentItem   ContentItem @relation(fields: [orgId, contentItemId], references: [orgId, id], onDelete: Cascade)
  filename      String
  mimeType      String
  url           String // public Bunny CDN URL
  path          String // storage-zone path (for deletion)
  width         Int
  height        Int
  createdAt     DateTime    @default(now())

  @@id([orgId, id])
  @@index([orgId, contentItemId])
}
